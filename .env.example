# ╔══════════════════════════════════════════════════════════════════╗
# ║           STOCK360 AI — VARIABLES DE ENTORNO                   ║
# ║  Copia este archivo como .env y completa TODOS los valores     ║
# ║  NUNCA subas el .env real a Git                                ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Aplicación ────────────────────────────────────────────────────────────────
ENVIRONMENT=production        # development | staging | production
DEBUG=false

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=stock360
POSTGRES_PASSWORD=CAMBIA_ESTA_CLAVE_AHORA        # ← OBLIGATORIO cambiar
POSTGRES_DB=stock360

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CAMBIA_REDIS_PASSWORD              # ← OBLIGATORIO cambiar

# ── JWT / Seguridad ───────────────────────────────────────────────────────────
# Genera con: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=GENERA_UN_SECRET_KEY_LARGO_Y_ALEATORIO  # ← OBLIGATORIO cambiar

# ── Anthropic API ─────────────────────────────────────────────────────────────
# Obtén tu clave en: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXX  # ← OBLIGATORIO

# ── AI Provider ───────────────────────────────────────────────────────────────
# anthropic | ollama | demo
AI_PROVIDER=ollama

# ── Ollama local ──────────────────────────────────────────────────────────────
# En Docker Desktop para Windows/Mac, host.docker.internal apunta a tu máquina
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:3b

# ── Admin inicial ─────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=CambiaEsto123!   # mínimo 8 chars, 1 mayúscula, 1 número

# ── CORS ──────────────────────────────────────────────────────────────────────
# Separados por coma, sin espacios
ALLOWED_ORIGINS=https://tudominio.com,https://www.tudominio.com

# ── WhatsApp Business API (Meta Cloud API) ────────────────────────────────────
# Configura en: https://developers.facebook.com/
WHATSAPP_TOKEN=your_whatsapp_business_token
WHATSAPP_PHONE_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_verify_token_here

# ── Facebook Messenger ────────────────────────────────────────────────────────
MESSENGER_PAGE_TOKEN=your_page_access_token
MESSENGER_VERIFY_TOKEN=your_verify_token_here

# ── Email SMTP (notificaciones) ───────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@tudominio.com

# ── Stripe ──────────────────────────────────────────────────────────────────────
# Configura en: https://dashboard.stripe.com/
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_SUCCESS_URL=https://yourdomain.com/payment-success
